#include <stdio.h>
#include <stdint.h>

#define SIZE 8

uint16_t buffer[SIZE];
int half_flag = 0;
int full_flag = 0;

void dma_fill()
{
    static int i = 0;

    buffer[i] = i * 10;
    i++;

    if(i == SIZE/2) {
        half_flag = 1;
    }

    if(i == SIZE) {
        full_flag = 1;
        i = 0;
    }
}

void process(uint16_t *data, int len)
{
    printf("Processing: ");
    for(int i = 0; i < len; i++) {
        printf("%d ", data[i]);
    }
    printf("\n");
}

int main()
{
    while(1)
    {
        dma_fill();

        if(half_flag)
        {
            half_flag = 0;
            process(&buffer[0], SIZE/2);
        }

        if(full_flag)
        {
            full_flag = 0;
            process(&buffer[SIZE/2], SIZE/2);
        }
    }
}
